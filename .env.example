# Firebase Configuration (Client)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Admin Configuration
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----"

# Email Configuration
# Pour Gmail:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password (pas votre mot de passe Gmail, mais un mot de passe d'application)

# Pour un serveur SMTP personnalisé:
EMAIL_HOST=smtp.your-domain.com
EMAIL_PORT=465
EMAIL_USER=contact@your-domain.com
EMAIL_PASSWORD=your_email_password

# Notes importantes:
# 1. EMAIL_HOST doit être le nom d'hôte SMTP (ex: smtp.gmail.com), PAS le port
# 2. EMAIL_PORT doit être 465 (SSL) ou 587 (TLS)
# 3. Pour Gmail, vous devez créer un "mot de passe d'application" dans les paramètres de sécurité
# 4. Assurez-vous que votre serveur SMTP autorise les connexions depuis votre serveur
